{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "EDA:",
    "AbortOnConnectFail": false,
    "ConnectTimeout": 5000,
    "SyncTimeout": 5000
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "eda-order-service",
    "Topics": {
      "Orders": "orders-events"
    }
  }
}
